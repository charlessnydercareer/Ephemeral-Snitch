{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/charlessnydercareer/Ephemeral-Snitch/schemas/session_record.schema.json",
  "title": "Project Snitch v1 Session Record",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "evidenceReceipt": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source",
        "observation",
        "evidence_sha256"
      ],
      "properties": {
        "source": {
          "type": "string",
          "minLength": 1
        },
        "observation": {},
        "evidence_sha256": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        }
      }
    }
  },
  "required": [
    "session_id",
    "request_id",
    "agent",
    "model_or_tool",
    "repo",
    "branch",
    "commit_before",
    "commit_after",
    "files_changed",
    "commands_claimed",
    "commands_verified",
    "tests_claimed",
    "tests_verified",
    "artifacts_written",
    "database_writes",
    "failures",
    "blockers",
    "deferred_work",
    "risk_flags",
    "redaction_applied",
    "content_capture"
  ],
  "properties": {
    "session_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_.-]{0,127}$"
    },
    "request_id": {
      "type": "string",
      "pattern": "^([0-9a-f]{8}-[0-9a-f]{4}-4[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}|req_[0-9a-f]{16,64})$"
    },
    "agent": {
      "type": "string"
    },
    "model_or_tool": {
      "type": "string"
    },
    "repo": {
      "type": "string"
    },
    "branch": {
      "type": "string"
    },
    "commit_before": {
      "type": "string"
    },
    "commit_after": {
      "type": "string"
    },
    "files_changed": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "commands_claimed": {
      "type": "array"
    },
    "commands_verified": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/evidenceReceipt"
      }
    },
    "tests_claimed": {
      "type": "array"
    },
    "tests_verified": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/evidenceReceipt"
      }
    },
    "artifacts_written": {
      "type": "array"
    },
    "database_writes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/evidenceReceipt"
      }
    },
    "failures": {
      "type": "array"
    },
    "blockers": {
      "type": "array"
    },
    "deferred_work": {
      "type": "array"
    },
    "risk_flags": {
      "type": "array"
    },
    "redaction_applied": {
      "const": true
    },
    "content_capture": {
      "const": false
    }
  }
}
